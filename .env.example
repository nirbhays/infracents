# =============================================================================
# InfraCents — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# All values below are placeholders — replace them before running.
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================

# Runtime environment: development | staging | production
ENVIRONMENT=development

# Application version (semver)
APP_VERSION=0.1.0

# Logging level: debug | info | warning | error
LOG_LEVEL=debug

# Comma-separated list of allowed CORS origins.
# In production, set this to your frontend domain only.
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# GITHUB APP
# =============================================================================

# GitHub App ID — found on your GitHub App's settings page.
# Example: 123456
GITHUB_APP_ID=

# GitHub App private key (PEM format).
# Generate from GitHub App settings → Private keys → Generate a private key.
# Paste the full PEM contents here. For multi-line, escape newlines with \n
# or use a file reference depending on your deployment method.
# Example: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_PRIVATE_KEY=

# Webhook secret for verifying incoming GitHub webhooks (HMAC-SHA256).
# Generate with: openssl rand -hex 32
# Must match the secret configured in your GitHub App settings.
GITHUB_WEBHOOK_SECRET=

# GitHub App OAuth client credentials (used for the Clerk GitHub OAuth flow).
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# PostgreSQL connection string.
# Local development: postgresql://infracents:infracents@localhost:5432/infracents
# Supabase production: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://infracents:infracents@localhost:5432/infracents

# Connection pool settings (tune for your workload)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# REDIS
# =============================================================================

# Redis connection string for price caching and rate limiting.
# Local development: redis://localhost:6379/0
# Upstash production: rediss://default:<password>@<endpoint>.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# Price cache time-to-live in seconds (default: 3600 = 1 hour).
# Lower values = fresher prices but more API calls.
REDIS_PRICE_CACHE_TTL=3600

# =============================================================================
# STRIPE (Billing)
# =============================================================================

# Stripe secret API key.
# Test mode: sk_test_xxxxx
# Live mode: sk_live_xxxxx
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for verifying incoming Stripe events.
# Found at: Developers → Webhooks → your endpoint → Signing secret
# Example: whsec_xxxxx
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each subscription tier.
# Create these in Stripe Dashboard → Products → Prices.
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_BUSINESS=price_xxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxx

# =============================================================================
# CLERK (Authentication)
# =============================================================================

# Clerk secret key for backend JWT validation.
# Found at: Clerk Dashboard → API Keys → Secret keys
CLERK_SECRET_KEY=

# Clerk publishable key for the frontend.
# Found at: Clerk Dashboard → API Keys → Publishable keys
# Note: This is also set in the frontend via NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
CLERK_PUBLISHABLE_KEY=

# Clerk JWT issuer URL for token verification.
# Example: https://clerk.xxxxx.dev
CLERK_JWT_ISSUER=

# =============================================================================
# MONITORING
# =============================================================================

# Sentry DSN for error tracking and performance monitoring.
# Only active in production (ENVIRONMENT=production).
# Found at: Sentry → Project Settings → Client Keys (DSN)
# Example: https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=

# =============================================================================
# CLOUD PRICING APIs
# =============================================================================

# AWS region for the Price List API.
# The pricing API is public (no credentials needed), but you can specify
# which regional endpoint to use. Default: us-east-1
AWS_REGION=us-east-1

# GCP Project ID for the Cloud Billing Catalog API.
# Required if you want to use authenticated GCP pricing lookups.
# The billing catalog is also available publicly for basic lookups.
GCP_PROJECT_ID=

# =============================================================================
# RATE LIMITING
# =============================================================================

# Max webhook requests per minute per GitHub App installation.
RATE_LIMIT_WEBHOOK=100

# Max dashboard API requests per minute per authenticated user.
RATE_LIMIT_API=60

# Max billing API requests per minute per authenticated user.
RATE_LIMIT_BILLING=10
